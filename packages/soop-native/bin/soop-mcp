#!/usr/bin/env node
// DEPRECATED: Use "soop mcp" instead. This shim will be removed in a future version.
process.stderr.write('[soop-mcp] Deprecated: use "soop mcp" instead.\n')
process.argv.splice(2, 0, 'mcp')
import('../dist/launcher-cli.mjs').catch((err) => {
  console.error('Failed to load soop CLI:', err.message)
  process.exit(1)
})
