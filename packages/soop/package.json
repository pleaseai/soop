{
  "name": "@pleaseai/soop",
  "version": "0.1.18",
  "description": "Repository Planning Graph - A unified framework for repository understanding and generation",
  "type": "module",
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/src/index.mjs",
  "types": "dist/src/index.d.mts",
  "bin": {
    "soop": "bin/soop",
    "soop-mcp": "bin/soop-mcp"
  },
  "keywords": [
    "repository",
    "code-generation",
    "code-understanding",
    "llm",
    "graph",
    "software-engineering",
    "ast"
  ],
  "author": "Minsu Lee <amond@amond.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleaseai/soop.git"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepack": "node -e \"const fs=require('fs');const pkg=fs.readFileSync('package.json','utf8');fs.writeFileSync('package.json.bak',pkg);const p=JSON.parse(pkg);delete p.devDependencies;fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "postpack": "node -e \"const fs=require('fs');fs.renameSync('package.json.bak','package.json');\""
  },
  "devDependencies": {
    "@pleaseai/soop-cli": "workspace:*",
    "@pleaseai/soop-encoder": "workspace:*",
    "@pleaseai/soop-graph": "workspace:*",
    "@pleaseai/soop-mcp": "workspace:*",
    "@pleaseai/soop-store": "workspace:*",
    "@pleaseai/soop-tools": "workspace:*",
    "@pleaseai/soop-utils": "workspace:*",
    "@pleaseai/soop-zerorepo": "workspace:*"
  },
  "dependencies": {
    "tree-sitter": "0.25.0",
    "tree-sitter-c": "0.24.1",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-kotlin": "0.3.8",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2"
  },
  "optionalDependencies": {
    "@pleaseai/soop-darwin-arm64": "0.1.18",
    "@pleaseai/soop-darwin-x64": "0.1.18",
    "@pleaseai/soop-linux-x64-glibc": "0.1.18",
    "@pleaseai/soop-linux-arm64-glibc": "0.1.18",
    "@pleaseai/soop-linux-x64-musl": "0.1.18",
    "@pleaseai/soop-linux-arm64-musl": "0.1.18",
    "@pleaseai/soop-win32-x64": "0.1.18",
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.13.0",
    "@surrealdb/node": "^2.6.0",
    "better-sqlite3": "^12.6.2"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "tree-sitter",
    "tree-sitter-c",
    "tree-sitter-c-sharp",
    "tree-sitter-cpp",
    "tree-sitter-go",
    "tree-sitter-java",
    "tree-sitter-kotlin",
    "tree-sitter-python",
    "tree-sitter-ruby",
    "tree-sitter-rust",
    "tree-sitter-typescript"
  ]
}
