{
  "name": "soop-please-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --watch packages/cli/src/cli.ts",
    "mcp": "bun run packages/mcp/src/server.ts",
    "build": "tsdown && bun run build:copy-assets",
    "build:copy-assets": "(cd packages/namu && bun run build:wasm) && mkdir -p packages/soop/dist/packages/cli/templates packages/soop/dist/wasm && cp packages/cli/src/templates/*.yml packages/soop/dist/packages/cli/templates/ && cp packages/namu/wasm/*.wasm packages/soop/dist/wasm/ && cp README.md LICENSE packages/soop/",
    "build:npm": "bun run scripts/generate-packages.ts",
    "publish:npm": "bun run build:npm && for dir in npm/soop-*/; do (cd \"$dir\" && npm publish --access public); done",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:file": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "format": "eslint --cache --fix .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/soop/dist packages/soop-native/dist",
    "prepare": "husky"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@antfu/eslint-config": "^7.7.2",
    "@pleaseai/soop-cli": "workspace:*",
    "@pleaseai/soop-encoder": "workspace:*",
    "@pleaseai/soop-graph": "workspace:*",
    "@pleaseai/soop-mcp": "workspace:*",
    "@pleaseai/soop-store": "workspace:*",
    "@pleaseai/soop-tools": "workspace:*",
    "@pleaseai/soop-utils": "workspace:*",
    "@pleaseai/soop-namu": "workspace:*",
    "@pleaseai/soop-zerorepo": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.0.18",
    "ai": "^6.0.116",
    "ai-sdk-provider-claude-code": "^3.4.2",
    "ai-sdk-provider-codex-cli": "^1.1.0",
    "commander": "^14.0.3",
    "eslint": "^10.1.0",
    "eslint-plugin-import-x": "^4.16.1",
    "husky": "^9.1.7",
    "tsdown": "^0.21.2",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.0.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "tree-sitter-cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pleaseai/soop.git"
  }
}
