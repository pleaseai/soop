#!/bin/sh

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$branch" = "main" ]; then
  echo ""
  echo "🚫 Direct commits to 'main' are not allowed."
  echo "   Please create a feature branch and open a Pull Request."
  echo ""
  echo "   git checkout -b feature/my-change"
  echo "   git commit ..."
  echo "   gh pr create"
  echo ""
  exit 1
fi
